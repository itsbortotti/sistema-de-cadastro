# PostgreSQL (ajuste user, password e nome do banco)
DATABASE_URL="postgresql://usuario:senha@localhost:5432/gestao_portfolio?schema=public"

# Porta do servidor (opcional)
PORT=3001

# Chave da sessão (obrigatório em produção)
SESSION_SECRET=sistema-cadastro-secret

# Origem permitida pelo CORS (opcional; padrão: http://localhost:5173)
# CORS_ORIGIN=http://localhost:5173

# Em produção com HTTPS, use COOKIE_SECURE=true
# COOKIE_SECURE=false
